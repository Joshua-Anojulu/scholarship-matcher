# Anthropic API key for server-side essay advice.
# Copy this file to .env and paste your real key there. .env is gitignored.
ANTHROPIC_API_KEY=

# Secret used to sign login session cookies.
# Use any long random string locally. In production, set a strong unique value
# in the host's environment (Render can generate one for you).
SESSION_SECRET=

# Database connection. Leave unset to use a local SQLite file (scholarships4u.db).
# In production set this to a Postgres URL, for example the one Render provides.
# DATABASE_URL=

# Set to true in production (HTTPS) so session cookies are sent only over HTTPS.
# Leave unset or false for local HTTP development.
# SESSION_COOKIE_SECURE=

# Transactional email for password reset. Create a Resend API key and verify
# the sender domain before filling these in. PUBLIC_APP_URL must be the public
# HTTPS URL users should return to after clicking a reset link.
# RESEND_API_KEY=
# EMAIL_FROM="Scholarships4U <no-reply@mail.scholarships4u.dev>"
# PUBLIC_APP_URL=https://scholarships4u.dev
